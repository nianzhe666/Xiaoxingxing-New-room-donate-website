/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: 'PingFang SC', 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.container {
  padding: 20rpx;
}

/* 卡片样式 */
.card {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

/* 标题样式 */
.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

/* 价格样式 */
.price {
  font-size: 28rpx;
  color: #f44336;
  margin-bottom: 10rpx;
}

/* 描述样式 */
.description {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 按钮样式 */
.btn {
  display: block;
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 10rpx;
  font-size: 32rpx;
  margin-top: 20rpx;
}

.btn-primary {
  background-color: #4CAF50;
  color: #fff;
}

.btn-disabled {
  background-color: #9e9e9e;
  color: #fff;
}

/* 状态标签 */
.status-badge {
  display: inline-block;
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  margin-bottom: 10rpx;
}

.status-badge.donated {
  background-color: #4CAF50;
  color: #fff;
}

.status-badge.not-donated {
  background-color: #ff9800;
  color: #fff;
}

/* 图片样式 */
.image {
  width: 100%;
  height: 300rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

/* 捐助人信息 */
.donor-info {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.donor-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.donor-name {
  font-size: 24rpx;
  color: #333;
}

/* 加载动画 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: #999;
  font-size: 28rpx;
}
