<view class="container">
  <view wx:if="{{ item }}" class="card">
    <image wx:if="{{ item.image }}" src="{{ item.image }}" class="image"></image>
    <view wx:else class="no-image">暂无图片</view>
    
    <view class="status-badge {{ item.donated ? 'donated' : 'not-donated' }}">
      {{ item.donated ? '已捐赠' : '待捐赠' }}
    </view>
    
    <text class="title">{{ item.name }}</text>
    <text class="price">价格: ¥{{ item.price }}</text>
    
    <view wx:if="{{ item.donated }}" class="donor-info">
      <image wx:if="{{ item.donor_avatar }}" src="{{ item.donor_avatar }}" class="donor-avatar"></image>
      <text class="donor-name">捐助人: {{ item.donor_name }}</text>
    </view>
    
    <view class="description-section">
      <text class="description-title">物品简介</text>
      <text class="description">{{ item.description }}</text>
    </view>
    
    <view class="action-buttons">
      <button wx:if="{{ !item.donated }}" class="btn btn-primary" bindtap="wechatPay">微信支付</button>
      <button wx:else class="btn btn-disabled" disabled>已捐赠</button>
      <button class="btn btn-secondary" bindtap="showContact">联系我们</button>
    </view>
  </view>
  
  <view wx:else class="loading">
    <text>加载中...</text>
  </view>
</view>

<!-- 联系我们弹窗 -->
<view wx:if="{{ showContactModal }}" class="modal">
  <view class="modal-content">
    <text class="modal-title">联系我们</text>
    <image wx:if="{{ contact.image }}" src="{{ contact.image }}" class="contact-image"></image>
    <text wx:else class="no-contact">暂未设置联系信息</text>
    <button class="modal-btn" bindtap="closeContact">关闭</button>
  </view>
</view>